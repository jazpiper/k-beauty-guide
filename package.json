{
  "name": "k-beauty-guide",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "start": "node ./node_modules/react-scripts/bin/react-scripts.js start",
    "build": "node ./node_modules/react-scripts/bin/react-scripts.js build",
    "test": "node ./node_modules/react-scripts/bin/react-scripts.js test",
    "test:crawler": "node crawler/tests/product-media-description-ingestion.test.cjs && node crawler/tests/local-fixture-runtime.test.cjs",
    "supabase:status": "npx supabase status",
    "supabase:reset": "npx supabase db reset",
    "supabase:functions:serve": "npx supabase functions serve",
    "supabase:functions:serve:analyzer": "npx supabase functions serve analyze-ingredient-text --no-verify-jwt",
    "smoke:supabase:analyzer": "node scripts/smoke-supabase-analyzer.mjs",
    "smoke:supabase:functions": "node scripts/smoke-supabase-functions.mjs",
    "smoke:supabase:local": "node scripts/smoke-supabase-local.mjs",
    "release:local": "node scripts/release-gate-local.mjs",
    "eject": "node ./node_modules/react-scripts/bin/react-scripts.js eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
